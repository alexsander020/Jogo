# This .gitignore file should be placed at the root of your Unity project directory

/[Ll]ibrary/
/[Tt]emp/
/[Oo]bj/
/[Bb]uild/
/[Bb]uilds/
/[U]serSettings/
/[M]emoryCaptures/
/[L]ogs/

# Autogenerated VS/MD/JetBrains solution and project files
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.opendb
*.VC.db

# Unity3D generated meta files
*.pidb.meta
*.pdb.meta
*.suo.meta

# Unity3D Crash Report files
sysinfo.txt

# Built Asset bundles
*.unity3d

# Crashlytics generated file
crashlytics-download.properties